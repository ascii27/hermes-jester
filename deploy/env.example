# Copy to .env on the VM and fill in. Never commit the real .env.

# SQLite file on the persistent disk.
JESTER_DB_PATH=/home/ubuntu/hermes-jester/data/jester.db

# Random secret that signs the UI session cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JESTER_SECRET_KEY=replace-me

# Public base URL of the service (used to build the OAuth redirect URI).
JESTER_BASE_URL=https://lectern-queenside.exe.xyz

# Google OAuth client (see deploy/README.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist of Google accounts permitted to use the UI.
JESTER_ALLOWED_EMAILS=michael.roy.galloway@gmail.com
